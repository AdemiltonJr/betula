---
const waContratar =
  'https://api.whatsapp.com/send?phone=5519983631912&text=Ol%C3%A1!%20Quero%20contratar%20um%20processo%20de%20recrutamento%20e%20sele%C3%A7%C3%A3o.';
---

<section class="hero">
  <img
    class="hero-bg-img"
    src="/assets/img/hero-photo.jpg"
    alt="Equipe da Bétula RH reunida durante um processo de recrutamento e seleção"
    width="1920"
    height="1080"
    fetchpriority="high"
  />
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="container hero-inner">
    <div class="hero-copy reveal">
      <div class="hero-text">
        <span class="eyebrow"><span class="dot"></span> Bétula RH · Campinas-SP</span>
        <h1>Solução integral em <em>recrutamento e seleção</em>.</h1>
        <p class="lead">
          Conectamos a estratégia e a cultura das organizações aos profissionais alinhados a cada
          contexto, do operacional à gestão, com processos éticos e assertivos.
        </p>
      </div>
      <div class="hero-actions">
        <a class="btn btn-wa" href={waContratar} target="_blank" rel="noopener">
          <svg class="ico" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.04 2c-5.46 0-9.9 4.44-9.9 9.9 0 1.75.46 3.45 1.32 4.95L2 22l5.3-1.38a9.9 9.9 0 0 0 4.74 1.2h.01c5.46 0 9.9-4.44 9.9-9.9S17.5 2 12.04 2Zm0 18.1a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.14.82.84-3.06-.2-.31a8.18 8.18 0 1 1 7.18 3.87Z"></path></svg>
          Quero contratar
        </a>
        <a class="btn btn-ghost-light" href="#metodo">Como atuamos</a>
      </div>
    </div>
  </div>
</section>
